{
  "name": "bidstorm",
  "version": "0.1.0",
  "private": true,
  "description": "BidStorm — real-time auction platform with intelligent recommendations",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "migrate": "bash database/run_migrations.sh",
    "migrate:seed": "bash database/run_migrations.sh --seed"
  },
  "engines": {
    "node": ">=20"
  }
}
