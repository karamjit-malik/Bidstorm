# ============================================================================
#  BidStorm environment variables
#  Copy to .env for local dev. For production, set these in your host's
#  dashboard (Railway/Render for the server, Vercel for the client) instead of
#  committing a file. See DEPLOY.md for the full runbook.
# ============================================================================

# ---- Server ----
PORT=5000
NODE_ENV=development          # set to "production" on the deployed server

# In production this is the deployed frontend origin(s). May be a comma-separated
# list so a Vercel production URL AND preview URLs are both allowed by CORS.
# e.g. CLIENT_ORIGIN=https://bidstorm.vercel.app,https://bidstorm-git-main-you.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# ---- Database ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=bidstorm_user
DB_PASSWORD=
DB_NAME=bidstorm
# Managed MySQL (Railway/Aiven/PlanetScale-incompatible; use MySQL 8) requires
# TLS. Set to "true" in production; leave "false"/unset for local MySQL.
DB_SSL=false

# ---- Auth ----
# Generate strong secrets:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Upload (local disk fallback) ----
# Used only when Cloudinary is NOT configured (i.e. local dev). On a host with an
# ephemeral filesystem these files vanish on redeploy — configure Cloudinary below.
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
MAX_FILES_PER_AUCTION=5

# ---- Image storage (Cloudinary) ----
# When all three are set, uploaded images go to Cloudinary (persistent CDN) and
# Sharp/local disk is bypassed. Leave blank locally to use disk. Free tier is
# plenty for a resume project. Values are on your Cloudinary dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Email ----
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@bidstorm.com

# ---- Client (Vite) ----
# Point these at the deployed server origin in production (set in Vercel env).
# e.g. VITE_API_URL=https://bidstorm-server.up.railway.app/api
#      VITE_SOCKET_URL=https://bidstorm-server.up.railway.app
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
